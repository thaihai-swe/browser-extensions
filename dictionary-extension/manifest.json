{
    "manifest_version": 3,
    "name": "Dictionary",
    "description": "Look up translations, dictionary entries, and AI explanations from selected text.",
    "version": "0.1.0",
    "icons": {
        "16": "assets/icon-16.png",
        "32": "assets/icon-32.png",
        "48": "assets/icon-48.png",
        "128": "assets/icon-128.png"
    },
    "permissions": [
        "storage",
        "contextMenus"
    ],
    "host_permissions": [
        "https://translate.googleapis.com/*",
        "https://api.dictionaryapi.dev/*",
        "https://*/*",
        "http://*/*"
    ],
    "background": {
        "service_worker": "src/background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "src/content.js"
            ],
            "css": [
                "src/ui/popup.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_icon": "assets/icon-128.png",
        "default_title": "Dictionary"
    },
    "options_page": "options/options.html"
}
